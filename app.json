{
  "name": "MeowChat Userbot",
  "description": "Private Telegram Userbot with AI chatbot using Pyrogram and MongoDB.",
  "keywords": ["telegram", "userbot", "chatbot", "pyrogram"],

  "env": {
    "API_ID": {
      "description": "Get from https://my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Get from https://my.telegram.org",
      "required": true
    },
    "STRING_SESSION": {
      "description": "Generate using Pyrogram session generator",
      "required": true
    },
    "MONGO_URL": {
      "description": "MongoDB connection string",
      "required": true
    },
    "API_KEY": {
      "description": "Chatbot API URL",
      "required": true
    },
    "API_URL": {
      "description": "Chatbot API URL",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    }
  },

  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
